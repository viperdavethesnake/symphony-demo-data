{
  "$comment": "Main config for symphony-demo-data generator. All knobs live here. Seeded = reproducible.",

  "meta": {
    "version": "0.1.0",
    "seed": 42,
    "tenantName": "Acme Corp"
  },

  "ad": {
    "domain": "acme.local",
    "netbios": "ACME",
    "functionalLevel": "Win2016",
    "rootOU": "Acme",

    "users": {
      "activeCount": 356,
      "disabledCount": 32,
      "terminatedCount": 12,
      "serviceAccountCount": 10
    },

    "departmentDistribution": {
      "Engineering": 90,
      "Sales": 60,
      "Operations": 45,
      "Marketing": 35,
      "CustomerSuccess": 35,
      "Product": 25,
      "Finance": 20,
      "IT": 18,
      "HR": 12,
      "Legal": 8,
      "Facilities": 5,
      "Executive": 3
    },

    "groups": {
      "createDepartmentGroups": true,
      "createRoleGroups": true,
      "createResourceGroups": true,
      "rolesPerUserMin": 1,
      "rolesPerUserMax": 3
    }
  },

  "scale": {
    "totalFiles": 10000000,
    "rootPath": "S:\\Share",
    "parallelThreads": 24,
    "batchSize": 5000
  },

  "folders": {
    "departmentShares": [
      "Sales", "Marketing", "Engineering", "Finance", "Legal",
      "HR", "IT", "Executive", "Operations", "CustomerSuccess",
      "Product", "Facilities"
    ],
    "commonShares": ["Public", "Scratch", "Archive", "Projects"],
    "minDepth": 3,
    "maxDepth": 6,
    "deepFolderPercent": 2,
    "deepFolderMaxDepth": 9
  },

  "ageDistribution": {
    "$comment": "Percentages must sum to 100. 80% of files older than 2 years.",
    "last30days": 5,
    "days30to365": 7,
    "years1to2": 8,
    "years2to5": 30,
    "years5to10": 30,
    "years10to15": 20
  },

  "timeConsistency": {
    "$comment": "btime <= mtime <= atime. Small % of files where atime was recently bumped by backup/scan.",
    "atimeRecentlyTouchedPercent": 10
  },

  "fileTypeMix": {
    "$comment": "Percentages by file count. Must sum to 100.",
    "office": 60,
    "images": 15,
    "archives": 7,
    "media": 4,
    "installers": 3,
    "cadCode": 3,
    "textLogs": 3,
    "junk": 5
  },

  "duplicates": {
    "exactDuplicatePercent": 8,
    "versionDriftPercent": 3,
    "versionDriftClusterSizeMin": 3,
    "versionDriftClusterSizeMax": 6
  },

  "acl": {
    "oversharePercent": 5,
    "orphanedSidPercent": 3,
    "brokenInheritancePercent": 4,
    "directUserAcePercent": 6,
    "ownerMismatchPercent": 10,
    "conflictingAcePercent": 1
  },

  "spaceSkew": {
    "$comment": "Pareto ownership — top X% of users own Y% of bytes.",
    "hoarderUserPercent": 10,
    "hoarderBytesShare": 60,
    "serviceAccountDominantBytesShare": 25
  }
}
